# Backend API (deployed Koyeb URL or http://localhost:3000 for dev)
VITE_API_URL=https://your-koyeb-app.koyeb.app

# Supabase Auth (Google OAuth)
# Set up Google provider in Supabase Dashboard > Authentication > Providers
# In Google Cloud Console, add the Supabase callback URL to your OAuth credentials
# In Supabase Dashboard > Authentication > URL Configuration, set Site URL and Redirect URLs
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
