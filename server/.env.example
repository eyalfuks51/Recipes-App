# Server
PORT=3000

# Moonshot AI — recipe extraction model (https://platform.moonshot.cn)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Supabase — database (https://app.supabase.com/project/_/settings/api)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# RapidAPI — shared key used for Instagram and YouTube scrapers
# NOTE: TikTok no longer calls RapidAPI directly from Koyeb (datacenter IP blocked).
#       TikTok traffic is routed via the Vercel proxy (see TIKTOK_PROXY_URL below).
RAPIDAPI_KEY=your_rapidapi_key_here

# RapidAPI YouTube — host for video details fallback (when transcript unavailable)
# Subscribed API: "YTStream - Download YouTube Videos" on RapidAPI
# Default: ytstream-download-youtube-videos.p.rapidapi.com
RAPIDAPI_YOUTUBE_HOST=ytstream-download-youtube-videos.p.rapidapi.com

# TikTok Vercel proxy — URL of the /api/tiktok-proxy serverless function on Vercel.
# Koyeb calls this instead of RapidAPI directly, because Vercel's IPs are not
# blocked by RapidAPI's TikTok scraper.
# Example: https://your-app.vercel.app/api/tiktok-proxy
TIKTOK_PROXY_URL=https://your-app.vercel.app/api/tiktok-proxy

# Shared secret between Koyeb and the Vercel proxy (prevents public misuse).
# Set the same value in both Koyeb and Vercel environment variables.
TIKTOK_PROXY_SECRET=your_shared_secret_here
