# Server
PORT=3000

# Apify — Instagram scraper actor (https://console.apify.com/account/integrations)
APIFY_TOKEN=your_apify_api_token_here

# Moonshot AI — recipe extraction model (https://platform.moonshot.cn)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Supabase — database (https://app.supabase.com/project/_/settings/api)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# RapidAPI — shared key used for Instagram, YouTube, and TikTok scrapers
RAPIDAPI_KEY=your_rapidapi_key_here

# RapidAPI YouTube — host for video details fallback (when transcript unavailable)
# Subscribed API: "YTStream - Download YouTube Videos" on RapidAPI
# Default: ytstream-download-youtube-videos.p.rapidapi.com
RAPIDAPI_YOUTUBE_HOST=ytstream-download-youtube-videos.p.rapidapi.com

# RapidAPI TikTok — host for video caption extraction ("Tiktok Scraper" API)
# Default: tiktok-scraper7.p.rapidapi.com
RAPIDAPI_TIKTOK_HOST=tiktok-scraper7.p.rapidapi.com
